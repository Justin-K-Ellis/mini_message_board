<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="./output_styles.css" />
    <script src="./script.js" defer></script>
    <title>MMB</title>
    </style>
  </head>
  <body>
    <div id="outer-container" class="w-11/12 md:w-1/2 mx-auto">
      <header class="py-2 flex justify-between">
        <div id="title-section">
          <h1 class="text-cyan-800 text-4xl font-bold">MMB</h1>
          <p class="text-cyan-600 text-xl">The Mini Message Board</p>
        </div>
        <button class="bg-cyan-500 hover:bg-cyan-600 text-white p-2 rounded-md shadow hover:shadow-md">
          <a href="/new">New Post</a>
        </button>
      </header>
      <hr>

      <main>
        <div>
          <% if (posts.length > 0) { %> <% posts.forEach(post => { %>
          <div class="shadow hover:shadow-md my-2 rounded p-2">
            <p class="font-bold"><%= post.user_name %></p>
            <p class="text-justify"><%= post.user_post %></p>
            <p class="text-cyan-600">Likes: <%= post.likes %></p>
            <form action="/delete/<%= post.id %>" method="POST">
              <button type="submit" id="delete" class="text-red-500">DELETE</button>
            </form>
            <p class="text-slate-500"><%= post.date %></p>
          </div>
          <% }) %> <% } %>
        </div>
      </main>
      <hr>
      <footer class="mx-auto py-8 md:py-12">
        <p class="text-center text-cyan-600">2024, Justin Klitgaard</p>
      </footer>
      
    </div>
  </body>
</html>
